{
  "name": "milpa/live",
  "description": "Render-target-agnostic live component primitives for the Milpa PHP framework: contracts, value objects, components, data sources, and the event-driven mount/handle/render lifecycle.",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.3",
    "milpa/core": "^0.6",
    "psr/log": "^3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpdoc-parser": "^2.3",
    "friendsofphp/php-cs-fixer": "^3.65"
  },
  "autoload": {
    "psr-4": {
      "Milpa\\Live\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Milpa\\Live\\Tests\\": "tests/",
      "Milpa\\Docs\\": "vendor/milpa/core/tools/gen-docs/"
    }
  }
}
